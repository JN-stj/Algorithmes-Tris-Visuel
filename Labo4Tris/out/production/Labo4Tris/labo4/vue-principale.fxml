<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import labo4.vue.VueVisualiseur?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="labo4.vue.ControleurPrincipal"
            style="-fx-background-color: #1e1e2e;">
    <top>
        <HBox style="-fx-background-color: #181825; -fx-padding: 6 12 6 12;">
            <Button fx:id="boutonParametres" text="⚙ Paramètres"
                    style="-fx-background-color: transparent; -fx-text-fill: #cdd6f4;"
                    onAction="#surParametres"/>
        </HBox>
    </top>

    <center>
        <VueVisualiseur fx:id="vueVisualiseur" width="660" height="380"/>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="8"
              style="-fx-background-color: #1e1e2e; -fx-padding: 8 16 8 16;">
            <Button fx:id="boutonArreter"  text="⏹ Arrêt"    onAction="#surArreter"  disable="true"/>
            <Button fx:id="boutonDemarrer" text="▶ Démarrer" onAction="#surDemarrer" disable="true"/>
        </HBox>
    </bottom>
</BorderPane>